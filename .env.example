# Baza danych — Supabase (https://supabase.com) lub lokalne PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/taskapp"

# NextAuth — wygeneruj: openssl rand -base64 32
NEXTAUTH_SECRET="wygeneruj-losowy-string-minimum-32-znaki"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth + Google Calendar API
# Konfiguracja: console.cloud.google.com > APIs & Services > Credentials > OAuth 2.0
# Dodaj Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Włącz API: Google Calendar API
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# Anthropic API — opcjonalne (AI priorytetyzacja zadań)
# Klucz: console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-xxx"

# Email SMTP — opcjonalne (powiadomienia o deadlinach)
# Gmail: włącz "Hasła do aplikacji" w ustawieniach konta Google
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="twoj@gmail.com"
SMTP_PASS="haslo-aplikacji-gmail"
