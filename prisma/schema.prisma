generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  googleTokens  Json?
  createdAt     DateTime   @default(now())
  tasks             Task[]
  exams             Exam[]
  categories        Category[]
  accounts          Account[]
  sessions          Session[]
  pushSubscriptions PushSubscription[]
  habits            Habit[]
  goals             Goal[]
  flashcardDecks    FlashcardDeck[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String?
  refresh_token     String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id     String @id @default(cuid())
  name   String
  color  String @default("#888888")
  userId String
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]
  exams Exam[]
}

model Task {
  id               String    @id @default(cuid())
  title            String
  description      String?
  deadline         DateTime?
  priority         Int       @default(3)
  done             Boolean   @default(false)
  doneAt           DateTime?
  googleEventId    String?
  reminderSentAt   DateTime?
  recurrence       String    @default("none") // none | daily | weekly | monthly
  recurrenceEnd    DateTime?
  subtasks         Json?     // [{id,text,done}]
  estimatedMinutes Int?      // e.g. 15, 30, 60, 120
  userId           String
  categoryId       String?
  goalId           String?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
  goal     Goal?     @relation(fields: [goalId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Goal {
  id          String    @id @default(cuid())
  title       String
  description String?
  emoji       String    @default("🎯")
  color       String    @default("#3b82f6")
  deadline    DateTime?
  archivedAt  DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Habit {
  id          String    @id @default(cuid())
  title       String
  description String?
  emoji       String    @default("✅")
  color       String    @default("#3b82f6")
  frequency   String    @default("daily") // daily | weekly:N (N times per week) | custom:N (every N days)
  archivedAt  DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions HabitCompletion[]
  createdAt   DateTime  @default(now())
}

model HabitCompletion {
  id      String   @id @default(cuid())
  habitId String
  date    String   // YYYY-MM-DD (local date, sv-SE)
  habit   Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exam {
  id         String   @id @default(cuid())
  title      String
  examDate   DateTime
  dailyHours Float    @default(1)
  userId     String
  categoryId String?
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category?      @relation(fields: [categoryId], references: [id])
  studySessions StudySession[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudySession {
  id            String   @id @default(cuid())
  examId        String
  date          DateTime
  topic         String
  hours         Float
  done          Boolean  @default(false)
  googleEventId String?
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model FlashcardDeck {
  id        String      @id @default(cuid())
  title     String
  emoji     String      @default("📚")
  color     String      @default("#7c5cff")
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards     Flashcard[]
  createdAt DateTime    @default(now())

  @@index([userId])
}

model Flashcard {
  id            String        @id @default(cuid())
  front         String
  back          String
  deckId        String
  deck          FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  // FSRS-4.5 scheduling state
  stability     Float         @default(0)
  difficulty    Float         @default(5)
  elapsedDays   Int           @default(0)
  scheduledDays Int           @default(0)
  reps          Int           @default(0)
  lapses        Int           @default(0)
  state         Int           @default(0)  // 0=New 1=Learning 2=Review 3=Relearning
  due           DateTime      @default(now())
  reviews       FlashcardReview[]
  createdAt     DateTime      @default(now())

  @@index([deckId])
  @@index([due])
}

model FlashcardReview {
  id         String    @id @default(cuid())
  cardId     String
  card       Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  rating     Int       // 1=Again 2=Hard 3=Good 4=Easy
  reviewedAt DateTime  @default(now())

  @@index([cardId])
}
